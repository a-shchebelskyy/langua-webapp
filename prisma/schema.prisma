datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model User {
  id        String   @id
  role      String   // "member" | "teacher"
  courses   Course[]
  bookings  Booking[]
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  image       String?
  instructor  User     @relation(fields: [instructorId], references: [id])
  instructorId String
  bookings    Booking[]
}

model Booking {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id])
  userId    String
  course    Course  @relation(fields: [courseId], references: [id])
  courseId  Int
  date      DateTime
  status    String
}